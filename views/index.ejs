<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cek Tomoro Coffee</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container py-5">
        <h1 class="text-center mb-4">📍 Status Toko Tomoro Coffee</h1>
        <div class="row">
            <% stores.forEach(store => { %>
            <div class="col-md-6 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-danger fw-bold"><%= store.storeName %></h5>
                        <p class="mb-2"><small class="text-muted"><%= store.storeAddress %></small></p>
                        <p class="mb-2"><strong>Jarak:</strong> <%= store.distance %> meter</p>
                        
                        <% if (store.businessStatus === 2) { %>
                            <p class="text-success fw-bold mb-1">✅ BUKA</p>
                            <a href="/menu/<%= store.storeCode %>" class="btn btn-danger btn-sm mt-2">Lihat Menu</a>
                        <% } else { %>
                            <p class="text-secondary fw-bold mb-1">❌ TUTUP / TIDAK TERSEDIA</p>
                            <button class="btn btn-secondary btn-sm mt-2" disabled>Lihat Menu</button>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</body>
</html>