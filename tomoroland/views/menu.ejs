<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu Tomoro - <%= storeCode %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .tomoro-bg-header { background-color: #df382c; color: white; }
        .product-img { width: 60px; height: 60px; object-fit: cover; border-radius: 8px; }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <a href="/" class="btn btn-outline-danger mb-4">⬅ Kembali ke Daftar Toko</a>
        <h2 class="mb-4">☕ Menu Tomoro Coffee Cabang: <span class="text-danger"><%= storeCode %></span></h2>
        
        <% if (menuGroups.length === 0) { %>
            <div class="alert alert-warning">Tidak ada menu yang tersedia atau token API telah kedaluwarsa.</div>
        <% } %>

        <% menuGroups.forEach(kategori => { %>
            <% if (kategori.items && kategori.items.length > 0) { %>
            <div class="card mb-4 shadow-sm">
                <div class="card-header tomoro-bg-header fw-bold fs-5">
                    <%= kategori.menuName %>
                </div>
                <ul class="list-group list-group-flush">
                    <% kategori.items.forEach(item => { %>
                    <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                        <div class="d-flex align-items-center">
                            <% if (item.picture && item.picture.mini) { %>
                                <img src="<%= item.picture.mini %>" alt="<%= item.name %>" class="product-img me-3 bg-secondary">
                            <% } else if (item.pictureUrls) { %>
                                <img src="<%= item.pictureUrls.split(',')[0] %>" alt="<%= item.name %>" class="product-img me-3 bg-secondary">
                            <% } %>
                            
                            <div>
                                <span class="fw-bold d-block fs-6"><%= item.name %></span>
                                <% if (item.desc) { %>
                                    <small class="text-muted d-block mb-1" style="max-width: 500px;"><%= item.desc %></small>
                                <% } %>
                                <span class="text-danger fw-semibold">Rp <%= item.price.toLocaleString('id-ID') %></span>
                                <% if (item.linePrice && item.linePrice > item.price) { %>
                                    <span class="text-decoration-line-through text-muted small ms-2">Rp <%= item.linePrice.toLocaleString('id-ID') %></span>
                                <% } %>
                            </div>
                        </div>

                        <div>
                            <% if (item.menuSecondaryTag === "Sold Out") { %>
                                <span class="badge bg-danger rounded-pill px-3 py-2">Habis</span>
                            <% } else { %>
                                <span class="badge bg-success rounded-pill px-3 py-2">Tersedia</span>
                            <% } %>
                        </div>
                    </li>
                    <% }) %>
                </ul>
            </div>
            <% } %>
        <% }) %>
    </div>
</body>
</html>